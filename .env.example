# ============================================================
# 凭证示例文件 —— 复制为 .env 后填入真实值（.env 已被 .gitignore 排除）
# 这些凭证供 tools/ 下的可选工具使用，不是框架运行的必需项
# ============================================================

# --- Z-Library 电子书下载（tools/book-finder.md）---
# 实际使用时存放在 .config/book-tools/.env
ZLIB_EMAIL=your_email_here
ZLIB_PASSWORD=your_password_here

# Anna's Archive（可选）
ANNAS_SECRET_KEY=

# 代理（中国大陆访问 Z-Library 可能需要）
# HTTPS_PROXY=http://127.0.0.1:7890

# --- 知乎文章下载（tools/zhihu-downloader.md）---
# 实际使用时存放在 .config/zhihu-tools/.env
ZHIHU_COOKIES=your_zhihu_cookie_here
